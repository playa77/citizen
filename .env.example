# ==========================================
# Citizen (v1.0) - Environment Template
# Copy to .env and fill in real values.
# ==========================================

# Database (required)
# PostgreSQL 16 with pgvector extension.
DATABASE_URL=postgresql+asyncpg://local_user:local_pass@localhost:5432/citizen_db

# LLM Routing (required)
# OpenRouter API key — only normalized text is sent to external providers.
OPENROUTER_API_KEY=

# LLM model selection (defaults match the deterministic fallback chain)
PRIMARY_MODEL=qwen/qwen3.6-plus
FALLBACK_MODEL_1=openai/gpt-5.4-nano
FALLBACK_MODEL_2=/openrouter/free

# Retry and timeout behaviour for the OpenRouter client
MAX_RETRIES=3
REQUEST_TIMEOUT=45.0

# Document ingestion limits
MAX_FILE_SIZE_MB=25
OCR_DPI=300
OCR_JPG_QUALITY=84

# Embedding / retrieval config
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536
TOP_K_RETRIEVAL=12
DIVERSITY_THRESHOLD=0.75

# Pipeline hard limit (seconds)
PIPELINE_TIMEOUT_SEC=120

# Application logging
LOG_LEVEL=INFO

# CORS — allowed origins for the static frontend
CORS_ORIGINS=["http://localhost:8000"]

# Consent / disclaimer
DISCLAIMER_VERSION=v1.0.0
