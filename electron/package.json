{
  "name": "citizen-desktop",
  "version": "1.0.0",
  "description": "Local-first, evidence-constrained legal reasoning engine for German law",
  "main": "dist/main.js",
  "author": "Citizen",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron dist/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "de.citizen.desktop",
    "productName": "Citizen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend-dist",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "icon": "assets/icon.png"
    },
    "toolsets": {
      "appimage": "1.0.2"
    }
  }
}
